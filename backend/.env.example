# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/invoice_maker

# OpenRouter AI (https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-pro

# Clerk Auth
# Use either CLERK_JWKS_URL directly or CLERK_ISSUER to derive it.
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_SECRET_KEY=

# Bootstrap owner email
# When you first enable Clerk against an existing production database,
# this email should match the existing owner's Clerk account so the
# legacy data can be claimed into that first real workspace.
BOOTSTRAP_OWNER_EMAIL=

# Optional bootstrap/company defaults
# These are now mainly used for development fallback and bootstrap migration.
COMPANY_NAME=Your Name
COMPANY_EMAIL=you@example.com
COMPANY_ADDRESS=123 Main St, City, State 12345
COMPANY_PHONE=555-123-4567

# AWS S3 for Image Uploads (optional - chat works without this)
# For multi-user production, use a private bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# Frontend URL for CORS (change for production)
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
DEBUG=true
